{
  "name": "calculadora",
  "version": "1.0.0",
  "description": "Backend da calculadora online com Fastify, PostgreSQL, JWT e histórico de cálculos",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/jwt": "^10.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "pg": "^8.16.3"
  }
}

#Banco de dados 
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco

DATABASE_CA_CERT=

#Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_uma_string_longa_e_aleatoria

#(pode ser igual ao JWT_SECRET)
COOKIE_SECRET=troque_por_outra_string_longa_e_aleatoria

#CORS 
# Ex: http://localhost:5500,https://meusite.com
ALLOWED_ORIGINS=http://localhost:5500

#Ambiente
# "production" ativa cookie Secure (HTTPS obrigatório)
NODE_ENV=development

#Servidor
PORT=3000